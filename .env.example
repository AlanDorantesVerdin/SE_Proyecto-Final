# ============================================================
#  Plantilla de variables de entorno
#  Copia este archivo como  .env  y rellena tus valores.
#  El archivo .env real NUNCA se sube a GitHub (ver .gitignore)
# ============================================================

# ----- Proveedor de IA (LLM) -----
# Proveedor a usar: gemini
LLM_PROVIDER=gemini
# Modelo de Gemini (gratuito y rápido)
LLM_MODEL=gemini-2.5-flash
# Tu API key de Google AI Studio (https://aistudio.google.com/apikey)
GEMINI_API_KEY=pega_aqui_tu_api_key

# ----- Base de datos -----
DATABASE_PATH=database/store.db

# ----- WhatsApp vía Twilio Sandbox -----
# Credenciales del panel de Twilio: https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Número del sandbox de WhatsApp (por defecto el de Twilio)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Validar la firma de Twilio en el webhook (pon 'true' en producción)
TWILIO_VALIDATE=false
# URL pública del túnel (ngrok). Solo se necesita si TWILIO_VALIDATE=true
# PUBLIC_BASE_URL=https://xxxx.ngrok-free.app
